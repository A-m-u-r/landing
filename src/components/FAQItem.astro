---
const { q, a } = Astro.props;
---
<details class="faq-item reveal">
  <summary>{q}</summary>
  <p>{a}</p>
</details>

<style>
  .faq-item {
    padding: 16px 18px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.8);
  }
  .faq-item summary {
    cursor: pointer;
    font-weight: 600;
  }
  .faq-item p {
    margin: 12px 0 0;
    color: var(--muted);
  }
</style>

