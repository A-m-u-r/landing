---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Спасибо">
  <section class="section">
    <div class="container card">
      <span class="badge">Заявка отправлена</span>
      <h1 class="display">Спасибо!</h1>
      <p class="lead">
        Я получила вашу заявку и свяжусь с вами в течение 24 часов.
      </p>
      <a class="button primary" href="/">Вернуться на главную</a>
    </div>
  </section>
</BaseLayout>

