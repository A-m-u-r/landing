---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { ensureCsrfToken, isAdminAuthenticated } from "../lib/admin/auth";

export const prerender = false;

if (!isAdminAuthenticated(Astro.cookies)) {
  return Astro.redirect("/admin/login");
}

Astro.response.headers.set("cache-control", "no-store");
const csrfToken = ensureCsrfToken(Astro.cookies);
const defaultSettings = {
  city: site.city,
  socialLabel: site.social.label,
  socialUrl: site.social.url,
  socialText: site.social.text,
};
const defaultPricing = site.pricing;
---

<BaseLayout title="Админка">
  <main class="admin-page">
    <input id="adminCsrfToken" type="hidden" value={csrfToken} />

    <section class="admin-hero">
      <div class="container hero-inner">
        <div class="hero-top">
          <a class="back-link" href="/">На сайт</a>
          <button id="logoutBtn" class="button secondary" type="button">Выйти</button>
        </div>
        <h1 class="display">Админка контента</h1>
        <p class="lead">
          Загрузка фото и видео, управление отзывами, экспорт и очистка данных.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container admin-grid">
        <article class="card panel settings">
          <div class="panel-head">
            <h2>Настройки</h2>
          </div>
          <form id="settingsForm" class="settings-form">
            <label>
              География
              <input id="settingsCity" name="city" type="text" required maxlength="80" />
            </label>
            <label>
              Соцсеть (название)
              <input id="settingsSocialLabel" name="socialLabel" type="text" required maxlength="24" />
            </label>
            <label>
              Ссылка на соцсеть
              <input id="settingsSocialUrl" name="socialUrl" type="url" required maxlength="200" />
            </label>
            <label>
              Отображаемый текст
              <input id="settingsSocialText" name="socialText" type="text" maxlength="120" />
            </label>
            <button class="button primary" type="submit">Сохранить настройки</button>
          </form>
        </article>

        <article class="card panel pricing-panel">
          <div class="panel-head">
            <h2>Пакеты</h2>
            <button id="addPricingBtn" class="button secondary" type="button">Добавить пакет</button>
          </div>
          <div id="pricingList" class="pricing-list"></div>
          <button id="savePricingBtn" class="button primary" type="button">Сохранить пакеты</button>
        </article>

        <article class="card panel">
          <div class="panel-head">
            <h2>Фото</h2>
            <span id="photoCount" class="count-chip">0</span>
          </div>
          <p class="panel-text">JPG, PNG, WEBP. Лимит 12 MB на файл.</p>
          <div class="upload-actions">
            <input id="photoInput" type="file" accept="image/jpeg,image/png,image/webp" multiple hidden />
            <button id="photoPicker" class="button secondary" type="button">Загрузить фото</button>
          </div>
          <div id="photoList" class="media-grid"></div>
        </article>

        <article class="card panel">
          <div class="panel-head">
            <h2>Видео</h2>
            <span id="videoCount" class="count-chip">0</span>
          </div>
          <p class="panel-text">MP4, WEBM, MOV. Лимит 150 MB на файл.</p>
          <div class="upload-actions">
            <input id="videoInput" type="file" accept="video/mp4,video/webm,video/quicktime" multiple hidden />
            <button id="videoPicker" class="button secondary" type="button">Загрузить видео</button>
          </div>
          <div id="videoList" class="media-grid"></div>
        </article>

        <article class="card panel reviews">
          <div class="panel-head">
            <h2>Отзывы</h2>
            <span id="reviewCount" class="count-chip">0</span>
          </div>
          <form id="reviewForm" class="review-form">
            <label>
              Имя
              <input id="author" name="author" type="text" required maxlength="80" />
            </label>
            <label>
              Подпись
              <input id="subtitle" name="subtitle" type="text" maxlength="120" />
            </label>
            <label>
              Оценка
              <select id="rating" name="rating">
                <option value="5">5</option>
                <option value="4">4</option>
                <option value="3">3</option>
                <option value="2">2</option>
                <option value="1">1</option>
              </select>
            </label>
            <label>
              Текст отзыва
              <textarea id="reviewText" name="text" required maxlength="1200"></textarea>
            </label>
            <button class="button primary" type="submit">Добавить отзыв</button>
          </form>
          <div id="reviewList" class="review-list"></div>
        </article>
      </div>
    </section>

    <section class="section actions-wrap">
      <div class="container">
        <article class="card actions">
          <h2>Операции</h2>
          <p>Экспортируйте данные в JSON или удалите весь админ-контент.</p>
          <div class="action-buttons">
            <button id="exportBtn" class="button primary" type="button">Экспорт JSON</button>
            <button id="clearBtn" class="button secondary danger" type="button">Очистить всё</button>
          </div>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>

<script is:inline>
  const csrfToken = document.getElementById("adminCsrfToken")?.value || "";
  const defaultSettings = ${JSON.stringify(defaultSettings)};
  const defaultPricing = ${JSON.stringify(defaultPricing)};
  const state = { media: [], reviews: [], settings: null, pricing: [] };

  const elements = {
    photoInput: document.getElementById("photoInput"),
    videoInput: document.getElementById("videoInput"),
    photoPicker: document.getElementById("photoPicker"),
    videoPicker: document.getElementById("videoPicker"),
    photoList: document.getElementById("photoList"),
    videoList: document.getElementById("videoList"),
    reviewForm: document.getElementById("reviewForm"),
    reviewList: document.getElementById("reviewList"),
    settingsForm: document.getElementById("settingsForm"),
    settingsCity: document.getElementById("settingsCity"),
    settingsSocialLabel: document.getElementById("settingsSocialLabel"),
    settingsSocialUrl: document.getElementById("settingsSocialUrl"),
    settingsSocialText: document.getElementById("settingsSocialText"),
    pricingList: document.getElementById("pricingList"),
    addPricingBtn: document.getElementById("addPricingBtn"),
    savePricingBtn: document.getElementById("savePricingBtn"),
    exportBtn: document.getElementById("exportBtn"),
    clearBtn: document.getElementById("clearBtn"),
    logoutBtn: document.getElementById("logoutBtn"),
    photoCount: document.getElementById("photoCount"),
    videoCount: document.getElementById("videoCount"),
    reviewCount: document.getElementById("reviewCount"),
  };

  function formatBytes(size) {
    if (!size || size < 1) return "0 B";
    const units = ["B", "KB", "MB", "GB"];
    const idx = Math.min(Math.floor(Math.log(size) / Math.log(1024)), units.length - 1);
    const value = size / Math.pow(1024, idx);
    return `${value.toFixed(value >= 10 || idx === 0 ? 0 : 1)} ${units[idx]}`;
  }

  function formatDate(value) {
    return new Date(value).toLocaleString("ru-RU");
  }

  async function api(path, options = {}) {
    const headers = new Headers(options.headers || {});
    if (csrfToken && !headers.has("x-csrf-token")) {
      headers.set("x-csrf-token", csrfToken);
    }

    const response = await fetch(path, {
      ...options,
      credentials: "same-origin",
      headers,
    });

    if (response.status === 401) {
      location.href = "/admin/login";
      throw new Error("Требуется повторный вход.");
    }

    if (!response.ok) {
      let message = "Ошибка запроса";
      try {
        const body = await response.json();
        message = body.error || message;
      } catch {}
      throw new Error(message);
    }

    const type = response.headers.get("content-type") || "";
    if (type.includes("application/json")) {
      return response.json();
    }
    return null;
  }

  function updateCounters() {
    elements.photoCount.textContent = String(state.media.filter((item) => item.kind === "photo").length);
    elements.videoCount.textContent = String(state.media.filter((item) => item.kind === "video").length);
    elements.reviewCount.textContent = String(state.reviews.length);
  }

  function createMediaCard(item) {
    const card = document.createElement("article");
    card.className = "media-card";

    const mediaWrap = document.createElement("div");
    mediaWrap.className = "media-preview";

    if (item.kind === "photo") {
      const image = document.createElement("img");
      image.src = item.url;
      image.alt = item.name;
      image.loading = "lazy";
      mediaWrap.appendChild(image);
    } else {
      const video = document.createElement("video");
      video.src = item.url;
      video.controls = true;
      video.preload = "metadata";
      mediaWrap.appendChild(video);
    }

    const title = document.createElement("h3");
    title.className = "media-title";
    title.textContent = item.name;

    const meta = document.createElement("p");
    meta.className = "media-meta";
    meta.textContent = `${formatBytes(item.size)} • ${formatDate(item.createdAt)}`;

    const actions = document.createElement("div");
    actions.className = "media-actions";

    const link = document.createElement("a");
    link.href = item.url;
    link.className = "text-btn";
    link.textContent = "Открыть";
    link.target = "_blank";
    link.rel = "noopener noreferrer";

    const removeBtn = document.createElement("button");
    removeBtn.type = "button";
    removeBtn.className = "text-btn danger";
    removeBtn.textContent = "Удалить";
    removeBtn.addEventListener("click", async () => {
      try {
        await api(`/api/admin/media/${item.id}`, { method: "DELETE" });
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось удалить файл.");
      }
    });

    actions.append(link, removeBtn);
    card.append(mediaWrap, title, meta, actions);
    return card;
  }

  function createReviewCard(item) {
    const card = document.createElement("article");
    card.className = "review-card";

    const top = document.createElement("div");
    top.className = "review-top";

    const name = document.createElement("strong");
    name.textContent = item.author;
    const subtitle = document.createElement("span");
    subtitle.className = "review-subtitle";
    subtitle.textContent = item.subtitle || "";
    const rating = document.createElement("span");
    rating.className = "rating";
    rating.textContent = `${"★".repeat(item.rating)}${"☆".repeat(5 - item.rating)}`;
    top.append(name, subtitle, rating);

    const text = document.createElement("p");
    text.textContent = item.text;

    const bottom = document.createElement("div");
    bottom.className = "review-bottom";
    const date = document.createElement("time");
    date.textContent = formatDate(item.createdAt);

    const removeBtn = document.createElement("button");
    removeBtn.type = "button";
    removeBtn.className = "text-btn danger";
    removeBtn.textContent = "Удалить";
    removeBtn.addEventListener("click", async () => {
      try {
        await api(`/api/admin/reviews/${item.id}`, { method: "DELETE" });
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось удалить отзыв.");
      }
    });

    bottom.append(date, removeBtn);
    card.append(top, text, bottom);
    return card;
  }

  function renderMedia() {
    const photos = state.media.filter((item) => item.kind === "photo");
    const videos = state.media.filter((item) => item.kind === "video");

    elements.photoList.innerHTML = "";
    elements.videoList.innerHTML = "";

    if (!photos.length) {
      const empty = document.createElement("p");
      empty.className = "empty";
      empty.textContent = "Пока нет загруженных фото.";
      elements.photoList.appendChild(empty);
    } else {
      photos.forEach((item) => elements.photoList.appendChild(createMediaCard(item)));
    }

    if (!videos.length) {
      const empty = document.createElement("p");
      empty.className = "empty";
      empty.textContent = "Пока нет загруженных видео.";
      elements.videoList.appendChild(empty);
    } else {
      videos.forEach((item) => elements.videoList.appendChild(createMediaCard(item)));
    }
  }

  function renderReviews() {
    elements.reviewList.innerHTML = "";
    if (!state.reviews.length) {
      const empty = document.createElement("p");
      empty.className = "empty";
      empty.textContent = "Отзывов пока нет.";
      elements.reviewList.appendChild(empty);
      return;
    }
    state.reviews.forEach((item) => elements.reviewList.appendChild(createReviewCard(item)));
  }

  function renderSettings() {
    const settings = { ...defaultSettings, ...(state.settings || {}) };
    if (elements.settingsCity) elements.settingsCity.value = settings.city || "";
    if (elements.settingsSocialLabel) elements.settingsSocialLabel.value = settings.socialLabel || "";
    if (elements.settingsSocialUrl) elements.settingsSocialUrl.value = settings.socialUrl || "";
    if (elements.settingsSocialText) elements.settingsSocialText.value = settings.socialText || "";
  }

  function createPricingRow(item, index) {
    const wrap = document.createElement("article");
    wrap.className = "pricing-item";
    wrap.dataset.index = String(index);

    const titleLabel = document.createElement("label");
    titleLabel.textContent = "Название";
    const titleInput = document.createElement("input");
    titleInput.type = "text";
    titleInput.required = true;
    titleInput.maxLength = 80;
    titleInput.value = item.title || "";
    titleInput.className = "pricing-title";
    titleLabel.appendChild(titleInput);

    const priceLabel = document.createElement("label");
    priceLabel.textContent = "Цена";
    const priceInput = document.createElement("input");
    priceInput.type = "text";
    priceInput.required = true;
    priceInput.maxLength = 40;
    priceInput.value = item.price || "";
    priceInput.className = "pricing-price";
    priceLabel.appendChild(priceInput);

    const pointsLabel = document.createElement("label");
    pointsLabel.textContent = "Что входит (каждый пункт с новой строки)";
    const pointsInput = document.createElement("textarea");
    pointsInput.rows = 4;
    pointsInput.maxLength = 1200;
    pointsInput.value = Array.isArray(item.points) ? item.points.join("\n") : "";
    pointsInput.className = "pricing-points";
    pointsLabel.appendChild(pointsInput);

    const removeBtn = document.createElement("button");
    removeBtn.type = "button";
    removeBtn.className = "text-btn danger";
    removeBtn.textContent = "Удалить";
    removeBtn.addEventListener("click", () => {
      state.pricing.splice(index, 1);
      renderPricing();
    });

    const actions = document.createElement("div");
    actions.className = "pricing-actions";
    actions.appendChild(removeBtn);

    wrap.append(titleLabel, priceLabel, pointsLabel, actions);
    return wrap;
  }

  function renderPricing() {
    if (!elements.pricingList) return;
    elements.pricingList.innerHTML = "";
    if (!state.pricing.length) {
      const empty = document.createElement("p");
      empty.className = "empty";
      empty.textContent = "Пакетов пока нет.";
      elements.pricingList.appendChild(empty);
      return;
    }
    state.pricing.forEach((item, index) => {
      elements.pricingList.appendChild(createPricingRow(item, index));
    });
  }

  function collectPricingFromForm() {
    if (!elements.pricingList) return [];
    const rows = Array.from(elements.pricingList.querySelectorAll(".pricing-item"));
    return rows.map((row) => {
      const title = row.querySelector(".pricing-title")?.value || "";
      const price = row.querySelector(".pricing-price")?.value || "";
      const pointsRaw = row.querySelector(".pricing-points")?.value || "";
      const points = pointsRaw
        .split("\n")
        .map((item) => item.trim())
        .filter((item) => item.length > 0);
      return { title, price, points };
    });
  }

  async function refresh() {
    const data = await api("/api/admin/content", { method: "GET" });
    state.media = data.media || [];
    state.reviews = data.reviews || [];
    state.settings = data.settings || null;
    state.pricing = Array.isArray(data.pricing) && data.pricing.length
      ? data.pricing
      : defaultPricing.map((item) => ({ ...item, points: [...(item.points || [])] }));
    updateCounters();
    renderMedia();
    renderReviews();
    renderSettings();
    renderPricing();
  }

  async function uploadFiles(files, kind) {
    for (const file of files) {
      const formData = new FormData();
      formData.set("kind", kind);
      formData.set("file", file);
      await api("/api/admin/upload", {
        method: "POST",
        body: formData,
      });
    }
  }

  function attachEvents() {
    elements.photoPicker.addEventListener("click", () => elements.photoInput.click());
    elements.videoPicker.addEventListener("click", () => elements.videoInput.click());

    elements.photoInput.addEventListener("change", async (event) => {
      const files = event.target.files;
      if (!files || !files.length) return;
      try {
        await uploadFiles(files, "photo");
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось загрузить фото.");
      } finally {
        event.target.value = "";
      }
    });

    elements.videoInput.addEventListener("change", async (event) => {
      const files = event.target.files;
      if (!files || !files.length) return;
      try {
        await uploadFiles(files, "video");
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось загрузить видео.");
      } finally {
        event.target.value = "";
      }
    });

    elements.reviewForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const formData = new FormData(elements.reviewForm);
      const payload = {
        author: String(formData.get("author") || ""),
        subtitle: String(formData.get("subtitle") || ""),
        text: String(formData.get("text") || ""),
        rating: Number(formData.get("rating") || 5),
      };

      try {
        await api("/api/admin/reviews", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify(payload),
        });
        elements.reviewForm.reset();
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось добавить отзыв.");
      }
    });

    elements.settingsForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      const payload = {
        city: elements.settingsCity?.value || "",
        socialLabel: elements.settingsSocialLabel?.value || "",
        socialUrl: elements.settingsSocialUrl?.value || "",
        socialText: elements.settingsSocialText?.value || "",
      };
      try {
        await api("/api/admin/settings", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify(payload),
        });
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось сохранить настройки.");
      }
    });

    elements.addPricingBtn.addEventListener("click", () => {
      state.pricing.push({ title: "", price: "", points: [] });
      renderPricing();
    });

    elements.savePricingBtn.addEventListener("click", async () => {
      const pricing = collectPricingFromForm();
      try {
        await api("/api/admin/pricing", {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify({ pricing }),
        });
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось сохранить пакеты.");
      }
    });

    elements.exportBtn.addEventListener("click", () => {
      window.location.href = "/api/admin/export";
    });

    elements.clearBtn.addEventListener("click", async () => {
      if (!confirm("Удалить все фото, видео и отзывы?")) return;
      try {
        await api("/api/admin/clear", { method: "POST" });
        await refresh();
      } catch (error) {
        alert(error.message || "Не удалось очистить данные.");
      }
    });

    elements.logoutBtn.addEventListener("click", async () => {
      try {
        await api("/api/admin/logout", { method: "POST" });
      } finally {
        location.href = "/admin/login";
      }
    });
  }

  (async () => {
    attachEvents();
    try {
      await refresh();
    } catch (error) {
      alert(error.message || "Не удалось загрузить данные админки.");
    }
  })();
</script>

<style>
  .admin-page {
    min-height: 100dvh;
  }

  .admin-hero {
    padding: 56px 0 32px;
  }

  .hero-inner {
    display: grid;
    gap: 14px;
  }

  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .hero-inner .display {
    margin: 6px 0;
  }

  .back-link {
    width: fit-content;
    font-weight: 600;
    color: var(--accent-2);
    padding: 8px 0;
  }

  .admin-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }

  .panel {
    padding: 24px;
  }

  .panel.reviews {
    grid-column: 1 / -1;
  }

  .panel.settings,
  .panel.pricing-panel {
    grid-column: 1 / -1;
  }

  .panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .panel-head h2,
  .actions h2 {
    margin: 0;
    font-family: "Fraunces", serif;
    font-size: 30px;
    line-height: 1.1;
  }

  .count-chip {
    min-width: 36px;
    text-align: center;
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(15, 89, 89, 0.12);
    color: var(--accent-2);
    font-weight: 700;
    font-size: 13px;
  }

  .panel-text {
    margin: 0 0 16px;
    color: var(--muted);
  }

  .upload-actions {
    margin-bottom: 18px;
  }

  .media-grid {
    display: grid;
    gap: 14px;
  }

  .media-card {
    border: 1px solid rgba(28, 28, 26, 0.12);
    border-radius: 14px;
    padding: 12px;
    display: grid;
    gap: 8px;
    background: rgba(255, 255, 255, 0.78);
  }

  .media-preview {
    border-radius: 10px;
    overflow: hidden;
    background: #111;
    aspect-ratio: 16 / 10;
  }

  .media-preview img,
  .media-preview video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-title {
    margin: 0;
    font-size: 15px;
    line-height: 1.3;
    word-break: break-word;
  }

  .media-meta {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
  }

  .media-actions {
    display: flex;
    gap: 14px;
  }

  .text-btn {
    border: none;
    background: transparent;
    color: var(--accent-2);
    padding: 0;
    cursor: pointer;
    font-weight: 600;
    font: inherit;
    text-decoration: none;
  }

  .text-btn.danger {
    color: #b42318;
  }

  .review-form {
    display: grid;
    gap: 12px;
  }

  .settings-form {
    display: grid;
    gap: 12px;
  }

  .settings-form label {
    display: grid;
    gap: 6px;
    font-weight: 500;
  }

  .settings-form input {
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(28, 28, 26, 0.18);
    padding: 11px 12px;
    font: inherit;
    background: #fff;
  }

  .review-form label {
    display: grid;
    gap: 6px;
    font-weight: 500;
  }

  .review-form input,
  .review-form textarea,
  .review-form select {
    width: 100%;
    border-radius: 12px;
    border: 1px solid rgba(28, 28, 26, 0.18);
    padding: 11px 12px;
    font: inherit;
    background: #fff;
  }

  .pricing-list {
