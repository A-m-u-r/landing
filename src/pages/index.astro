---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../sections/Hero.astro";
import About from "../sections/About.astro";
import Services from "../sections/Services.astro";
import Showreel from "../sections/Showreel.astro";
import Testimonials from "../sections/Testimonials.astro";
import Process from "../sections/Process.astro";
import Pricing from "../sections/Pricing.astro";
import FAQ from "../sections/FAQ.astro";
import Contact from "../sections/Contact.astro";
import Footer from "../sections/Footer.astro";
import { getAdminData } from "../lib/admin/storage";
import { mergeSiteData } from "../lib/site";

const adminData = await getAdminData().catch(() => ({ media: [], reviews: [], settings: null, pricing: [] }));
const content = mergeSiteData(adminData);
---

<BaseLayout title="Ведущая событий">
  <header class="nav">
    <div class="container nav-inner">
      <a class="brand" href="#hero">{content.brand}</a>
      <nav>
        <a href="#services">Форматы</a>
        <a href="#showreel">Шоу?рил</a>
        <a href="#process">Процесс</a>
        <a href="#contact" class="button secondary">Связаться</a>
      </nav>
    </div>
  </header>

  <main>
    <Hero site={content} />
    <About site={content} />
    <Services site={content} />
    <Showreel media={adminData.media} />
    <Testimonials reviews={adminData.reviews} site={content} />
    <Process site={content} />
    <Pricing site={content} />
    <FAQ site={content} />
    <Contact site={content} />
  </main>
  <Footer site={content} />
</BaseLayout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(12px);
    background: rgba(246, 243, 239, 0.8);
    border-bottom: 1px solid rgba(28, 28, 26, 0.08);
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 0;
  }
  .brand {
    font-weight: 700;
  }
  nav {
    display: flex;
    gap: 18px;
    align-items: center;
  }
  nav a {
    font-weight: 600;
  }
  @media (max-width: 760px) {
    nav a:not(.button) {
      display: none;
    }
  }
</style>

