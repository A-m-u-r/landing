---
import SectionTitle from "../components/SectionTitle.astro";
const { site } = Astro.props;
---
<section class="section" id="contact">
  <div class="container">
    <SectionTitle
      eyebrow="Контакт"
      title="Проверим дату и обсудим сценарий"
      text="Оставьте заявку — я отвечу в течение дня и уточню детали." />
    <div class="contact-grid">
      <form
        class="card contact-form reveal"
        action={`https://formsubmit.co/${site.email}`}
        method="POST"
      >
        <input type="hidden" name="_subject" value="Новая заявка на ведущую" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_next" value="/thanks" />
        <label>
          Имя
          <input type="text" name="name" placeholder="Как к вам обращаться" required />
        </label>
        <label>
          Телефон
          <input type="tel" name="phone" placeholder="+7 (___) ___?__?__" required />
        </label>
        <label>
          Дата события
          <input type="date" name="date" required />
        </label>
        <label>
          Формат и детали
          <textarea name="details" rows="4" placeholder="Свадьба, корпоратив, место, время"></textarea>
        </label>
        <button class="button primary" type="submit">Отправить заявку</button>
      </form>
      <div class="contact-info reveal">
        <div class="card">
          <h3>Контакты</h3>
          <p>Телефон: {site.phone}</p>
          <p>Email: {site.email}</p>
          <p>География: {site.city}</p>
          <p>
            {site.social.label}:{" "}
            <a href={site.social.url} target="_blank" rel="noopener noreferrer">
              {site.social.text}
            </a>
          </p>
        </div>
        <div class="card">
          <h3>Что дальше?</h3>
          <p>Я предложу 2–3 концепции программы и уточню ожидания.</p>
          <p>Вы получите смету и тайминг в течение 24 часов.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(280px, 1.1fr) minmax(240px, 0.9fr);
    gap: 24px;
  }
  .contact-form {
    display: grid;
    gap: 16px;
  }
  .contact-form label {
    display: grid;
    gap: 6px;
    font-weight: 600;
  }
  .contact-form input,
  .contact-form textarea {
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid rgba(28, 28, 26, 0.15);
    font-family: inherit;
  }
  .contact-info {
    display: grid;
    gap: 16px;
  }
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

