---
import SectionTitle from "../components/SectionTitle.astro";

const { media = [] } = Astro.props;
const videos = media.filter((item) => item?.kind === "video").slice(0, 2);
const photos = media.filter((item) => item?.kind === "photo").slice(0, 4);
const hasMedia = videos.length > 0 || photos.length > 0;
---
<section class="section showreel" id="showreel">
  <div class="container">
    <SectionTitle
      eyebrow="Шоурил"
      title="Сцены, эмоции, атмосфера"
      text={
        hasMedia
          ? "Блок автоматически обновляется из админки после загрузки контента."
          : "Пока нет загруженных файлов. Добавьте фото и видео в админке."
      }
    />

    {hasMedia ? (
      <div class="reel-grid reveal">
        <article class="media-main card">
          {videos.length ? (
            <video src={videos[0].url} controls preload="metadata" playsinline />
          ) : (
            <div class="reel-placeholder"><span>Добавьте первое видео в админке</span></div>
          )}
          <div class="reel-meta">
            <h3>{videos.length ? videos[0].name : "Видео отсутствует"}</h3>
            <p>
              {videos.length
                ? "Видео загружено из защищенной админки."
                : "Как только загрузите mp4/webm/mov, видео появится здесь автоматически."}
            </p>
          </div>
        </article>

        <div class="media-side">
          {photos.map((photo) => (
            <article class="media-thumb card">
              <img src={photo.url} alt={photo.name} loading="lazy" />
            </article>
          ))}
          {!photos.length && (
            <article class="media-thumb placeholder card">
              <span>Добавьте фотографии в админке</span>
            </article>
          )}
        </div>
      </div>
    ) : (
      <div class="reel-card reveal">
        <div class="reel-placeholder">
          <span>Видео 16:9</span>
        </div>
        <div class="reel-meta">
          <h3>Динамика, которая держит зал</h3>
          <p>В админке можно загрузить видео и фото, и этот блок начнет наполняться автоматически.</p>
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .showreel {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(246, 243, 239, 0.4));
  }

  .reel-grid {
    display: grid;
    grid-template-columns: minmax(280px, 1.2fr) 1fr;
    gap: 20px;
    align-items: start;
  }

  .media-main {
    padding: 16px;
    border-radius: var(--radius-lg);
  }

  .media-main video {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    object-fit: cover;
    background: #101010;
  }

  .media-side {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(2, minmax(120px, 1fr));
  }

  .media-thumb {
    padding: 8px;
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 120px;
    display: grid;
    place-items: center;
  }

  .media-thumb img {
    width: 100%;
    height: 100%;
    border-radius: 10px;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .media-thumb.placeholder span {
    color: var(--muted);
    text-align: center;
    font-size: 14px;
  }

  .reel-card {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(240px, 1.2fr) 1fr;
    align-items: center;
    background: var(--surface);
    padding: 28px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
  }

  .reel-placeholder {
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    background: linear-gradient(120deg, #f4d1bd, #cde7de);
    display: grid;
    place-items: center;
    font-weight: 600;
  }

  .reel-meta {
    padding: 6px 4px 2px;
  }

  .reel-meta p {
    color: var(--muted);
  }

  @media (max-width: 900px) {
    .reel-grid,
    .reel-card {
      grid-template-columns: 1fr;
    }

    .media-side {
      grid-template-columns: repeat(2, minmax(120px, 1fr));
    }
  }
</style>
