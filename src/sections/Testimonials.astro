---
import SectionTitle from "../components/SectionTitle.astro";
import Testimonial from "../components/Testimonial.astro";
import { site } from "../data/site";

const { reviews = [] } = Astro.props;
const display = reviews.length
  ? reviews.map((item) => ({
      name: item.subtitle ? `${item.author}, ${item.subtitle}` : item.author,
      text: item.text,
      rating: item.rating,
    }))
  : site.testimonials.map((item) => ({
      name: item.name,
      text: item.text,
      rating: 5,
    }));
---
<section class="section" id="testimonials">
  <div class="container">
    <SectionTitle
      eyebrow="Отзывы"
      title="Слова гостей после события"
      text={reviews.length ? "Отзывы загружаются из админки в реальном времени." : "Теплые впечатления — лучший показатель качества."} />
    <div class="testimonials-grid">
      {display.map((item) => (
        <Testimonial name={item.name} text={item.text} rating={item.rating} />
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }
</style>

